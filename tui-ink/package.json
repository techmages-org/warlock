{
  "name": "warlock-tui-ink",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Warlock TUI — Ink (React-for-CLI) front end mirroring the web HUD, hitting the same FastAPI backend.",
  "bin": {
    "warlock-tui": "dist/cli.js",
    "warlock-chat": "dist/chat.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.78.1",
    "@earendil-works/pi-ai": "^0.78.1",
    "ink": "5.0.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "18.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "18.3.18",
    "@types/ws": "8.5.13",
    "ink-testing-library": "4.0.0",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
